rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isPredictionOwner() { return signedIn() && request.resource.data.uid == request.auth.uid; }
    function predictionMatchOpen() {
      return exists(/databases/$(database)/documents/matches/$(request.resource.data.matchId))
        && get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.locked == false
        && get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.status != "finished";
    }
    match /admins/{uid} { allow read: if signedIn() && request.auth.uid == uid; allow write: if false; }
    match /users/{uid} { allow read: if signedIn(); allow create, update: if signedIn() && request.auth.uid == uid; }
    match /matches/{matchId} { allow read: if signedIn(); allow create, update, delete: if isAdmin(); }
    match /predictions/{predictionId} { allow read: if signedIn(); allow create, update: if isPredictionOwner() && predictionMatchOpen(); allow delete: if signedIn() && resource.data.uid == request.auth.uid; }
  }
}
